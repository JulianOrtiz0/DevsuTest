  "main": "index.js",
  "scripts": {
    "test:local": "npx cypress run --env version=local",
    "test:qa": "npx cypress run --env allure=true version=qa ",
    "open:qa": "npx cypress open --env version=qa",
    "test:prod": "npx cypress run --env version=prod",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:clear": "rm -rf allure-results allure-report"
  },
